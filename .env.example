# ============================================
# SocialGenius-AI - Environment Variables
# ============================================
# Copy this file to backend/.env and fill in the values

# --- Database (SQLite para desarrollo) ---
DATABASE_URL=sqlite+aiosqlite:///./socialgenius.db
SYNC_DATABASE_URL=sqlite:///./socialgenius.db

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI (Hugging Face para desarrollo) ---
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# --- Stripe (Test Mode) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- App ---
APP_NAME=SocialGenius
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]
